# Подключается автоматически через Railway Variable Reference: ${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Секрет для подписи JWT-токенов — задайте сложное случайное значение
JWT_SECRET=change-me-to-a-random-secret-string

# Для уведомлений о новых заявках с сайта в Telegram-группу
BOT_TOKEN=
GROUP_ID=

# (позже) Eskiz.uz токен для отправки SMS
ESKIZ_TOKEN=
